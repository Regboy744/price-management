# Optional app vars (not used by scraper runtime today)
PORT=3000
NODE_ENV=production
# Browser
CHROME_PATH=/usr/bin/google-chrome
# Login
AUTO_LOGIN=true
MS_USERNAME=gilberto.r441@centra.ie
MS_PASSWORD=Mu$grave27!
AAD_USERNAME=
AAD_PASSWORD=
MS_KEEP_SIGNED_IN=false
# Capture/dropdown workflow
SKIP_SELECTS=false
SELECT_DELAY_MS=120
SELECT_POSTBACK_TIMEOUT_MS=6000
REPORT_RENDER_TIMEOUT_MS=20000
POST_RENDER_CAPTURE_WAIT_MS=3000
PREFERRED_CAPTURE_TIMEOUT_MS=5000
FORCED_ASYNC_RETRIES=2
# Profile (currently not effectively used; code forces fresh profile in capture/scrape:all)
FRESH_PROFILE=false
# Scrape performance
REQUEST_DELAY_MS=150
PARALLEL_TABS=1
PARALLEL_TAB_STAGGER_MS=300
STORE_RETRY_COUNT=1
# Memory protection
CAPTURE_MAX_ITEMS=350
CAPTURE_MAX_BYTES_MB=200
# HTTP replay behavior
HTTP_REQUEST_TIMEOUT_MS=15000
HTTP_REQUEST_RETRIES=1
HTTP_REQUEST_RETRY_DELAY_MS=200
# Telemetry MEM_TELEMETRY_INTERVAL_MS=30000
# Single-curl scrape mode only
SCRAPE_SKIP_FORM_OVERRIDES=false
